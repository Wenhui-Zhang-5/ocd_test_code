# Frontend API target
VITE_API_ORIGIN=http://localhost:8001
VITE_API_PREFIX=/api

# Optional: mock spectrum object root path used by src/data/mock.js
# VITE_SPECTRUM_ROOT=/Users/yourname/path/to/OCD_master_test/spectrum_data

# Optional: enable optimization queue API for Run Monitor pages (0=mock, 1=api+SSE)
VITE_ENABLE_OPTIMIZATION_API=0
